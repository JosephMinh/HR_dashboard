// HR Dashboard Prisma Schema
// All entities: User, Job, Candidate, Application, AuditLog, SetPasswordToken,
// HeadcountProjection, Tradeoff

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  RECRUITER
  VIEWER
}

enum JobStatus {
  OPEN
  OFFER
  AGENCY
  HIRED
  HIRED_CW
  NOT_STARTED
  UNKNOWN
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PipelineHealth {
  AHEAD
  ON_TRACK
  BEHIND
}

enum CandidateSource {
  REFERRAL
  LINKEDIN
  CAREERS_PAGE
  AGENCY
  OTHER
}

enum ApplicationStage {
  NEW
  SCREENING
  INTERVIEWING
  FINAL_ROUND
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

// =============================================================================
// MODELS
// =============================================================================

model User {
  id                 String     @id @default(uuid())
  name               String
  email              String     @unique
  passwordHash       String
  role               UserRole   @default(VIEWER)
  active             Boolean    @default(true)
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  auditLogs          AuditLog[]
  setPasswordTokens  SetPasswordToken[]
}

model Job {
  id                 String          @id @default(uuid())
  title              String
  department         String
  description        String          @db.Text
  location           String?
  hiringManager      String?
  recruiterOwner     String?
  status             JobStatus       @default(OPEN)
  priority           JobPriority     @default(MEDIUM)
  pipelineHealth     PipelineHealth?
  isCritical         Boolean         @default(false)
  openedAt           DateTime?
  targetFillDate     DateTime?
  closedAt           DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // WFP import fields
  importKey          String?         @unique
  sourceRow          Int?
  sourceSheet        String?
  tempJobId          Int?
  hibobId            Int?
  level              String?
  employeeType       String?
  function           String?
  horizon            String?
  asset              String?
  keyCapability      String?
  milestone          String?
  businessRationale  String?
  corporatePriority  String?
  functionalPriority String?
  fpaApproved        String?
  fpaLevel           String?
  fpaNote            String?
  fpaTiming          String?
  talentAssessment   String?
  recruitingStatus   String?
  hiredName          String?
  isTradeoff         Boolean         @default(false)
  notes              String?

  applications            Application[]
  headcountProjections    HeadcountProjection[]
  tradeoffSources         Tradeoff[] @relation("Tradeoff_sourceJobIdToJob")
  tradeoffTargets         Tradeoff[] @relation("Tradeoff_targetJobIdToJob")

  @@index([status])
  @@index([isCritical])
  @@index([pipelineHealth])
  @@index([updatedAt])
  @@index([targetFillDate])
  // Composite indexes for dashboard queries
  @@index([status, isCritical])
  @@index([status, pipelineHealth])
  // WFP import indexes
  @@index([employeeType])
  @@index([function])
  @@index([horizon])
  @@index([level])
  @@index([status, horizon])
  @@index([tempJobId])
}

model Candidate {
  id             String           @id @default(uuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  linkedinUrl    String?
  currentCompany String?
  location       String?
  source         CandidateSource?
  resumeKey      String?
  resumeName     String?
  notes          String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  applications   Application[]

  @@index([firstName])
  @@index([lastName])
  @@index([email])
}

model Application {
  id              String           @id @default(uuid())
  jobId           String
  candidateId     String
  stage           ApplicationStage @default(NEW)
  recruiterOwner  String?
  interviewNotes  String?          @db.Text
  stageUpdatedAt  DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate       Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@index([stage])
  // Composite index for filtering applications by job and stage
  @@index([jobId, stage])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entityType  String
  entityId    String
  beforeJson  Json?
  afterJson   Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
}

model SetPasswordToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model HeadcountProjection {
  id           String    @id
  importKey    String    @unique
  sourceRow    Int
  tempJobId    Int?
  rawTempJobId String?
  matchedJobId String?
  department   String
  employeeName String?
  level        String?
  jobTitle     String?
  startDate    DateTime?
  monthlyFte   Json
  createdAt    DateTime  @default(now())

  matchedJob   Job?      @relation(fields: [matchedJobId], references: [id])

  @@index([matchedJobId])
  @@index([tempJobId])
}

model Tradeoff {
  id               String   @id
  importKey        String   @unique
  sourceRow        Int
  rowType          String
  sourceTempJobId  Int?
  sourceJobId      String?
  sourceDepartment String?
  sourceLevel      String?
  sourceTitle      String?
  targetTempJobId  Int?
  targetJobId      String?
  targetDepartment String?
  targetLevel      String?
  targetTitle      String?
  levelDifference  Int?
  status           String?
  notes            String?
  createdAt        DateTime @default(now())

  sourceJob        Job?     @relation("Tradeoff_sourceJobIdToJob", fields: [sourceJobId], references: [id])
  targetJob        Job?     @relation("Tradeoff_targetJobIdToJob", fields: [targetJobId], references: [id])

  @@index([sourceJobId])
  @@index([sourceTempJobId])
  @@index([targetJobId])
  @@index([targetTempJobId])
}
