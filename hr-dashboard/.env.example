# HR Dashboard Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string
# See: https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://user:password@localhost:5432/hr_dashboard?schema=public"

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Auth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-replace-in-production"

# Trust the host header (required for VPS/proxy environments)
AUTH_TRUST_HOST=true

# =============================================================================
# STORAGE (S3 or S3-Compatible like MinIO)
# =============================================================================

# Required: Bucket name for resume storage
STORAGE_BUCKET=hr-dashboard-resumes

# Optional: AWS region (defaults to us-east-1)
STORAGE_REGION=us-east-1

# Optional: Custom endpoint for S3-compatible services (MinIO, DigitalOcean Spaces, etc.)
# Uncomment for MinIO local development:
# STORAGE_ENDPOINT=http://localhost:9000

# Optional: AWS credentials (required for MinIO and non-IAM AWS environments)
# For AWS with IAM roles, these can be omitted
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# =============================================================================
# LOCAL DEVELOPMENT WITH MINIO
# =============================================================================
# To use MinIO for local development:
# 1. Start MinIO: docker compose -f docker-compose.dev.yml up -d minio
# 2. Create bucket: ./scripts/setup-minio.sh
# 3. Uncomment and use these values:
#
# STORAGE_BUCKET=hr-dashboard
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
