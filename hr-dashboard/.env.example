# HR Dashboard Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string
# See: https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://user:password@localhost:5432/hr_dashboard?schema=public"

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Auth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-replace-in-production"

# Trust the host header (required for VPS/proxy environments)
AUTH_TRUST_HOST=true

# =============================================================================
# SEEDING (prisma db seed)
# =============================================================================

# Required: admin account created by seed script
# ADMIN_NAME=Admin User
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMeNow!123

# =============================================================================
# STORAGE (S3 or S3-Compatible like MinIO)
# =============================================================================

# Required: Bucket name for resume storage
STORAGE_BUCKET=hr-dashboard-resumes

# Optional: AWS region (defaults to us-east-1)
STORAGE_REGION=us-east-1

# Optional: Custom endpoint for S3-compatible services (MinIO, DigitalOcean Spaces, etc.)
# Uncomment for MinIO local development:
# STORAGE_ENDPOINT=http://localhost:9000

# Optional: AWS credentials (required for MinIO and non-IAM AWS environments)
# For AWS with IAM roles, these can be omitted
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# =============================================================================
# LOCAL DEVELOPMENT WITH MINIO
# =============================================================================
# To use MinIO for local development:
# 1. Start MinIO: docker compose -f docker-compose.dev.yml up -d minio
# 2. Create bucket: ./scripts/setup-minio.sh
# 3. Uncomment and use these values:
#
# STORAGE_BUCKET=hr-dashboard
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
# Required for email delivery (invite links, password resets).
# Without these, email sends will fail and callers receive an error.
#
# --- Local development (Mailpit) ---
# Start: docker run -d --name hr-dashboard-dev-mailpit -p 1025:1025 -p 8025:8025 --restart unless-stopped axllent/mailpit:latest --smtp-auth-accept-any --smtp-auth-allow-insecure
# Web UI: http://localhost:8025
#
# APP_URL=http://localhost:3000
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SENDER_EMAIL=noreply@hr-dashboard.local
# SENDER_NAME=HR Dashboard
#
# --- Production ---
# APP_URL=https://your-domain.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SENDER_EMAIL=noreply@your-domain.com
# SENDER_NAME=HR Dashboard

# =============================================================================
# RATE LIMITING (Upstash Redis - Production)
# =============================================================================
# For production deployments, configure Upstash Redis to enable distributed
# rate limiting across serverless instances. Without these, an in-memory
# fallback is used (suitable only for local development).
#
# Get credentials at: https://console.upstash.com/
#
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here
